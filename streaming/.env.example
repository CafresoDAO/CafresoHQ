# ── CafresoAI Streaming Infrastructure — Environment Variables ────────────────
# Copy to .env and fill in your values:  cp .env.example .env

# ── Fleet API ─────────────────────────────────────────────────────────────────
FLEET_API_SECRET=change-me-to-a-strong-random-secret
FLEET_API_PORT=8080

# ── TURN Server (coturn) ─────────────────────────────────────────────────────
# Shared secret for HMAC time-limited credentials (fleet-api generates per-session)
TURN_SECRET=change-me-to-a-random-hex-string
# Public URL clients use to reach the TURN relay
TURN_URL=turn:hq.cafreso.com:3478
TURN_TLS_URL=turns:hq.cafreso.com:5349
# External IP of the TURN server (for relay-address in coturn)
TURN_EXTERNAL_IP=
# TLS cert paths (from Caddy / Let's Encrypt)
TURN_TLS_CERT=/etc/caddy/certificates/acme-v02.api.letsencrypt.org-directory/hq.cafreso.com/hq.cafreso.com.crt
TURN_TLS_KEY=/etc/caddy/certificates/acme-v02.api.letsencrypt.org-directory/hq.cafreso.com/hq.cafreso.com.key

# ── Moonlight-Web-Stream (per-session, fleet-api fills these) ─────────────────
SUNSHINE_HOST=10.0.0.50
SUNSHINE_PORT=47989
SIGNALING_PORT=8443
SESSION_ID=default

# ── Hyper-V ──────────────────────────────────────────────────────────────────
HYPERV_GOLD_IMAGES_PATH=C:\HyperV\GoldImages
HYPERV_WORKSPACE_VM_PATH=C:\HyperV\Workspaces
HYPERV_VSWITCH_NAME=Default Switch

# ── VM Pool Pre-warming ──────────────────────────────────────────────────────
VM_POOL_SIZE=2
VM_POOL_REPLENISH_SEC=60
VM_POOL_MAX_AGE_HOURS=12

# ── Session Limits ───────────────────────────────────────────────────────────
MAX_SESSIONS_PER_USER=5
SESSION_IDLE_TIMEOUT_SEC=14400
SESSION_HEALTH_INTERVAL_SEC=30

# ── Admin ────────────────────────────────────────────────────────────────────
FLEET_ADMIN_PRINCIPALS=your-icp-principal-here

# ── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me
PROMETHEUS_RETENTION=30d

# ── Session Recording ────────────────────────────────────────────────────────
RECORDING_CODEC=libx264
RECORDING_QUALITY=23
RECORDING_RESOLUTION=1920x1080
RECORDINGS_PATH=./recordings

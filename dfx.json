{
  "version": 1,
  "canisters": {
    "cafresoai_frontend": {
      "type": "assets",
      "source": ["frontend/build"],
      "frontend": {
        "entrypoint": "frontend/build/index.html"
      },
      "build": "echo 'NOTE: run `npm --prefix frontend run build` before `dfx deploy`'",
      "dependencies": ["cafresoai_keys"]
    },
    "cafresoai_keys": {
      "type": "motoko",
      "main": "src/cafresoai_keys/main.mo",
      "declarations": {
        "node_compatibility": true,
        "output": "frontend/src/lib/declarations/cafresoai_keys"
      }
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "networks": {
    "ic": {
      "providers": ["https://icp0.io"],
      "type": "persistent"
    },
    "local": {
      "bind": "127.0.0.1:4943",
      "type": "ephemeral"
    }
  },
  "output_env_file": ".env.dfx"
}

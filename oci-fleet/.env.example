# ── CafresoHQ OCI Fleet — environment template ───────────────────────────────
# Copy to .env and fill in your values.
# .env is .gitignored — never commit real credentials.

# ── OCI Tenancy ───────────────────────────────────────────────────────────────
OCI_TENANCY_ID=ocid1.tenancy.oc1..aaaa...
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..aaaa...
OCI_REGION=us-chicago-1

# ── OCIR (OCI Container Registry) ────────────────────────────────────────────
# Region key for OCIR — us-ashburn-1=iad, us-chicago-1=ord, us-phoenix-1=phx
# Full list: https://docs.oracle.com/en-us/iaas/Content/Registry/Concepts/registryprerequisites.htm
OCIR_REGION_KEY=iad
OCIR_TENANCY_NAMESPACE=your-tenancy-namespace
OCIR_REPO=cafresoai-serve

# ── Network — Container Instances must be in a VCN subnet ────────────────────
OCI_SUBNET_ID=ocid1.subnet.oc1..aaaa...
OCI_AVAILABILITY_DOMAIN=AD-1

# ── Object Storage vault bucket ───────────────────────────────────────────────
OCI_VAULT_NAMESPACE=your-tenancy-namespace
OCI_VAULT_BUCKET=cafresoai-fleet-vault

# ── Agent CLI keys ───────────────────────────────────────────────────────────
# Server-wide keys: all users in this container share them.
# Leave blank to require users to supply their own via HQ Settings (BYOK).
# BYOK keys are encrypted client-side (AES-256-GCM) and injected per-request;
# server env always wins — set here to lock the backend for all users.
#
# Upgrade path: replace the client-side device key with ICP vetKeys
# (vetkd_encrypted_key) so decryption requires the user's II principal.
#
# LMSTUDIO_BASE_URL/LMSTUDIO_MODEL — the managed-brain default. When set, every
# newly-provisioned container is bootstrapped to use this endpoint keylessly,
# ahead of every cloud provider below (see oci-fleet/hermes-bootstrap.py
# _model_block branch 0). Point it at the self-hosted LM Studio box through the
# gateway's private Twingate proxy, NOT its raw LAN IP — OCI containers can't
# reach your home/office network directly.
LMSTUDIO_BASE_URL=http://<twingate-proxy-host>:1234/v1
LMSTUDIO_MODEL=bionic                # exact model id LM Studio's /v1/models reports
OPENROUTER_API_KEY=sk-or-...         # fallback DEFAULT when no managed brain is set (open-weights, free tier)
GROQ_API_KEY=gsk_...                 # alternate open-weights (needs paid tier — free 413s on Hermes' prompt)
ANTHROPIC_API_KEY=sk-ant-api03-...   # claude Code CLI (BYOK)
OPENAI_API_KEY=sk-...                # codex CLI → OpenAI direct (BYOK)
GOOGLE_API_KEY=...                   # Gemini API (BYOK)

# ── WebRTC TURN / STUN (for Hyper-V + OCI streaming) ────────────────────────
# Required for WebRTC streams crossing NAT (external users).
# coturn runs from streaming/docker-compose.coturn.yml.
# HMAC-SHA1 shared secret must match streaming/turnserver.conf static-auth-secret.
TURN_URL=turn:hq.cafreso.com:3478
TURN_SECRET=change-me-match-turnserver-conf

# ── Container sizing (ARM A1 Flex) ───────────────────────────────────────────
# 1 OCPU / 6 GB RAM per user — change if needed
FLEET_OCPUS=1
FLEET_MEMORY_GB=6

# ── Fleet registry file ───────────────────────────────────────────────────────
# fleet-manager.py reads/writes this file to track user → container mappings
FLEET_REGISTRY=oci-fleet/fleet.json

# ── Workspaces API (portal service — the streaming host, not the gateway) ──
# Identity: on-chain session tokens verified with HQ_SESSION_SECRET (same hex
# as the keys canister setHqSessionSecret). Admin: principals allowed to call
# /admin/* (comma-separated). Entitlement read from OPERATOR_STATE_URL.
# CAFRESOHQ_DEV=1 is the ONLY way to run without FLEET_API_SECRET.
#HQ_SESSION_SECRET=
#FLEET_ADMIN_PRINCIPALS=
#OPERATOR_STATE_URL=https://ydacz-riaaa-aaaal-qxeja-cai.icp0.io
#CAFRESOHQ_DEV=

# ── CafresoHQ OCI Fleet — environment template ───────────────────────────────
# Copy to .env and fill in your values.
# .env is .gitignored — never commit real credentials.

# ── OCI Tenancy ───────────────────────────────────────────────────────────────
OCI_TENANCY_ID=ocid1.tenancy.oc1..aaaa...
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..aaaa...
OCI_REGION=us-chicago-1

# ── OCIR (OCI Container Registry) ────────────────────────────────────────────
# Region key for OCIR — us-ashburn-1=iad, us-chicago-1=ord, us-phoenix-1=phx
# Full list: https://docs.oracle.com/en-us/iaas/Content/Registry/Concepts/registryprerequisites.htm
OCIR_REGION_KEY=iad
OCIR_TENANCY_NAMESPACE=your-tenancy-namespace
OCIR_REPO=cafresoai-serve

# ── Network — Container Instances must be in a VCN subnet ────────────────────
OCI_SUBNET_ID=ocid1.subnet.oc1..aaaa...
OCI_AVAILABILITY_DOMAIN=AD-1

# ── Object Storage vault bucket ───────────────────────────────────────────────
OCI_VAULT_NAMESPACE=your-tenancy-namespace
OCI_VAULT_BUCKET=cafresoai-fleet-vault

# ── Agent CLI keys ───────────────────────────────────────────────────────────
# Server-wide keys: all users in this container share them.
# Leave blank to require users to supply their own via HQ Settings (BYOK).
# BYOK keys are encrypted client-side (AES-256-GCM) and injected per-request;
# server env always wins — set here to lock the backend for all users.
#
# Upgrade path: replace the client-side device key with ICP vetKeys
# (vetkd_encrypted_key) so decryption requires the user's II principal.
GROQ_API_KEY=gsk_...                 # DEFAULT for new users (open-weights, free tier)
ANTHROPIC_API_KEY=sk-ant-api03-...   # claude Code CLI (BYOK)
OPENAI_API_KEY=sk-...                # codex CLI → OpenAI direct (BYOK)
GOOGLE_API_KEY=...                   # Gemini API (BYOK)

# ── Container sizing (ARM A1 Flex) ───────────────────────────────────────────
# 1 OCPU / 6 GB RAM per user — change if needed
FLEET_OCPUS=1
FLEET_MEMORY_GB=6

# ── Fleet registry file ───────────────────────────────────────────────────────
# fleet-manager.py reads/writes this file to track user → container mappings
FLEET_REGISTRY=oci-fleet/fleet.json

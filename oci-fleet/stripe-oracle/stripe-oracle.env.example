# /etc/cafresoai/stripe-oracle.env  — secrets for the Stripe oracle.
# Install root-owned, mode 600:
#   sudo install -m 600 -o root -g root stripe-oracle.env /etc/cafresoai/stripe-oracle.env
# After editing: sudo systemctl restart stripe-oracle
#
# Until STRIPE_SECRET_KEY is set the service is INERT: /session returns 503 and
# no card buttons work (the frontend keeps PUBLIC_CARD_PAYMENTS=off anyway).

# Stripe secret API key. Use the TEST key first (sk_test_…), switch to sk_live_…
# only after a full test-mode 4242-card run passes.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_…). Get it after you register the
# endpoint  https://hq.cafreso.com/stripe/webhook  in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=

# 32-byte hex seed for the oracle's Ed25519 identity. Generate ONCE on the VM:
#   node -e "const c=require('crypto');console.log(c.randomBytes(32).toString('hex'))"
# Then derive the principal to register on-chain (setOraclePrincipal):
#   node /opt/stripe-oracle/print-principal.mjs <SEED_HEX>
# Keep this secret — whoever holds it can mark card orders paid (free plans,
# never theft).
ORACLE_SEED_HEX=

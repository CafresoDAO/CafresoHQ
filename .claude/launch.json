{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "hq-ui-static",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "8934",
        "--directory",
        "hq-ui"
      ],
      "port": 8934
    },
    {
      "name": "frontend-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "--prefix",
        "frontend",

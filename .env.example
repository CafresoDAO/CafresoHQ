# Deploy/ops config for the gateway scripts (oci-fleet/deploy-fleet-api.sh,
# scripts/deploy-oracle-stage*.sh). Copy to `.env` (gitignored) and fill in.
# All values are read from the environment, so you can also export them directly.

# Public IP / hostname of the Caddy TLS gateway VM. REQUIRED by the deploy scripts.
GATEWAY_IP=

# SSH login + key for the gateway VM.
GATEWAY_SSH_USER=ubuntu
GATEWAY_SSH_KEY=$HOME/.ssh/cafreso_tls_gateway

# OCI API credentials (used by deploy-fleet-api.sh to seed the VM).
OCI_CONFIG=$HOME/.oci/config
OCI_KEY=$HOME/.oci/oci_api_key.pem
# Used by the .claude/*.py OCI helpers as well:
OCI_KEY_FILE=$HOME/.oci/oci_api_key.pem

# Docker config holding OCIR pull credentials (copied to the gateway).
DOCKER_CONFIG_JSON=$HOME/.docker/config.json

# Stripe-oracle source dir (defaults to <repo>/oci-fleet/stripe-oracle).
# ORACLE_SRC=

# OpenClaw elevated allowlist (start-elevated.sh); defaults to $HOME/Documents.
# OPENCLAW_ALLOWED_DIRS=$HOME/Documents

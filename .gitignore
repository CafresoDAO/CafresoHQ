# ── Build output ─────────────────────────────────────────
dist/
build/
electron/dist/

# ── npm build deps (re-generated by build-win.bat) ────────
electron/node_modules/

# ── Python caches ─────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Logs ──────────────────────────────────────────────────
*.log
serve_stdout.log
serve_stderr.log

# ── OS junk ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Local secrets / env overrides ─────────────────────────
.env
.env.local

# ── OCI Fleet ─────────────────────────────────────────────
oci-fleet/fleet.json
oci-fleet/.env
oci-fleet/.env.host
oci-fleet/data/

# ── Streaming infrastructure secrets ─────────────────────
streaming/.env

# ── ICP canister build output ─────────────────────────────
.dfx/
icp/.dfx/
icp/node_modules/

# ── Claude Code worktrees (embedded git repos) ────────────
.claude/worktrees/

# ── electron-builder cache ────────────────────────────────
electron/.icon-ico
electron/CafresoHQ/

# ── Node / SvelteKit / Vite build artifacts ───────────────
node_modules/
.svelte-kit/
.tmp-build/

# ── HQ UI build output (scripts/build_ui_bundle.mjs) ──────
dist-ui/

# ── dfx generated env (canister ids) ──────────────────────
.env.dfx

# Generated HQ-UI asset-canister build dir (scripts/build_hq_ui.py)
hq-ui/
scripts/__pycache__/

# Runtime state / caches (never ship)
hq-state/
oci-fleet/_or.json

# Machine-local Claude Code settings (per-developer paths/permissions)
.claude/settings.local.json
worker.env

# Workspace portal / streaming (local state + secrets)
oci-fleet/.env.host
oci-fleet/sessions.db*
streaming/.env

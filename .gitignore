# ── Build output ─────────────────────────────────────────
dist/
build/
electron/dist/

# ── npm build deps (re-generated by build-win.bat) ────────
electron/node_modules/

# ── Python caches ─────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Logs ──────────────────────────────────────────────────
*.log
serve_stdout.log
serve_stderr.log

# ── OS junk ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Local secrets / env overrides ─────────────────────────
.env
.env.local

# ── OCI Fleet ─────────────────────────────────────────────
oci-fleet/fleet.json
oci-fleet/.env
oci-fleet/data/

# ── ICP canister build output ─────────────────────────────
.dfx/
icp/.dfx/
icp/node_modules/

# ── Claude Code worktrees (embedded git repos) ────────────
.claude/worktrees/

# ── electron-builder cache ────────────────────────────────
electron/.icon-ico
electron/OpenclawHQ/

# ── Node / SvelteKit / Vite build artifacts ───────────────
node_modules/
.svelte-kit/
.tmp-build/


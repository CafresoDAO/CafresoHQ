filters:
  and:
    - file.inFolder("06-Daily-Learning")
properties:
  file.name:
    displayName: Date
  topic:
    displayName: Topic
  tags:
    displayName: Tags
views:
  - type: table
    name: Chronological
    order:
      - file.name
      - topic
      - tags
    sort:
      - property: file.name
        direction: DESC
